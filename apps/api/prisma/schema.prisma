generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


enum ScenarioRunStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
}

model ScenarioRun {
  id           String            @id @default(uuid())
  traceId      String            @unique
  scenarioName String
  status       ScenarioRunStatus @default(PENDING)

  input        Json
  output       Json?
  errorMessage String?

  startedAt    DateTime
  finishedAt   DateTime?
  durationMs   Int?

  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([scenarioName])
  @@index([status])
  @@index([startedAt])
}